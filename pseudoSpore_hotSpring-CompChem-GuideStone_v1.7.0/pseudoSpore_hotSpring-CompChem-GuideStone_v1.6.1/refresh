#!/usr/bin/env bash
# pseudoSpore GuideStone freshness check — thin Rust launcher
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

resolve_binary() {
    if [[ -x "$SCRIPT_DIR/bin/nest-validate" ]]; then
        echo "$SCRIPT_DIR/bin/nest-validate"
    elif command -v nest-validate &>/dev/null; then
        command -v nest-validate
    elif [[ -x "$SCRIPT_DIR/../control/plumed_nest/nest-validate/target/release/nest-validate" ]]; then
        echo "$SCRIPT_DIR/../control/plumed_nest/nest-validate/target/release/nest-validate"
    else
        return 1
    fi
}

BINARY="$(resolve_binary)" || {
    echo "ERROR: nest-validate binary not found."
    echo "Build: cd control/plumed_nest/nest-validate && cargo build --release"
    exit 1
}

exec "$BINARY" guidestone refresh "$SCRIPT_DIR"
