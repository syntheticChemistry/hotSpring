# 2D Cremer-Pople puckering CVs: 2D24 +1 subsite xylose
# Ring atom GROMACS indices: C1,C2,C3,C4,C5,O5 = 6278,6286,6290,6294,6282,6285

puck: PUCKERING ATOMS=6278,6286,6290,6294,6282,6285

METAD ...
LABEL=metad
ARG=puck.qx,puck.qy
PACE=500
HEIGHT=1.2
SIGMA=0.02,0.02
FILE=HILLS_2d
BIASFACTOR=15.0
TEMP=300.0
GRID_MIN=-0.12,-0.12
GRID_MAX=0.12,0.12
GRID_BIN=100,100
... METAD

PRINT STRIDE=10 ARG=puck.theta,puck.phi,puck.amplitude,puck.qx,puck.qy,puck.qz,metad.bias FILE=COLVAR_2d
