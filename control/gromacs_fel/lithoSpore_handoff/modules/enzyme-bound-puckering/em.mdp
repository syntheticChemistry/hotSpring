; Energy minimization for GH10 xylanase + xylose ES complex

integrator  = steep
emtol       = 1000.0
emstep      = 0.01
nsteps      = 50000

nstlist         = 10
cutoff-scheme   = Verlet
ns_type         = grid
coulombtype     = PME
rcoulomb        = 1.2
rvdw            = 1.2
rvdw-switch     = 1.0
vdwtype         = Cut-off
vdw-modifier    = Force-switch
DispCorr        = no
pbc             = xyz
