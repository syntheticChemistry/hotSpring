############ Representative plumed file to calculate histogram or free energy profiles along puckering coordinates from COLVAR file ########

### Here for glycan A2G2S2 ###

# Read pucker coordinates phi and theta from COLVAR file

puck1: READ FILE=COLVAR_theta.0 IGNORE_TIME VALUES=puck1.theta STRIDE=10
puck2: READ FILE=COLVAR_theta.0 IGNORE_TIME VALUES=puck2.theta STRIDE=10
puck3: READ FILE=COLVAR_theta.0 IGNORE_TIME VALUES=puck3.theta STRIDE=10
puck4: READ FILE=COLVAR_theta.0 IGNORE_TIME VALUES=puck4.theta STRIDE=10
puck5: READ FILE=COLVAR_theta.0 IGNORE_TIME VALUES=puck5.theta STRIDE=10
puck6: READ FILE=COLVAR_theta.0 IGNORE_TIME VALUES=puck6.theta STRIDE=10
puck7: READ FILE=COLVAR_theta.0 IGNORE_TIME VALUES=puck7.theta STRIDE=10
puck8: READ FILE=COLVAR_theta.0 IGNORE_TIME VALUES=puck8.theta STRIDE=10
puck9: READ FILE=COLVAR_theta.0 IGNORE_TIME VALUES=puck9.theta STRIDE=10
puck10: READ FILE=COLVAR_theta.0 IGNORE_TIME VALUES=puck10.theta STRIDE=10
puck11: READ FILE=COLVAR_theta.0 IGNORE_TIME VALUES=puck11.theta STRIDE=10

puckp1: READ FILE=COLVAR_theta.0 IGNORE_TIME VALUES=puck1.phi STRIDE=10
puckp2: READ FILE=COLVAR_theta.0 IGNORE_TIME VALUES=puck2.phi STRIDE=10
puckp3: READ FILE=COLVAR_theta.0 IGNORE_TIME VALUES=puck3.phi STRIDE=10
puckp4: READ FILE=COLVAR_theta.0 IGNORE_TIME VALUES=puck4.phi STRIDE=10
puckp5: READ FILE=COLVAR_theta.0 IGNORE_TIME VALUES=puck5.phi STRIDE=10
puckp6: READ FILE=COLVAR_theta.0 IGNORE_TIME VALUES=puck6.phi STRIDE=10
puckp7: READ FILE=COLVAR_theta.0 IGNORE_TIME VALUES=puck7.phi STRIDE=10
puckp8: READ FILE=COLVAR_theta.0 IGNORE_TIME VALUES=puck8.phi STRIDE=10
puckp9: READ FILE=COLVAR_theta.0 IGNORE_TIME VALUES=puck9.phi STRIDE=10
puckp10: READ FILE=COLVAR_theta.0 IGNORE_TIME VALUES=puck10.phi STRIDE=10
puckp11: READ FILE=COLVAR_theta.0 IGNORE_TIME VALUES=puck11.phi STRIDE=10

# Compute 1D histogram along theta

theta1: HISTOGRAM ARG=puck1.theta BANDWIDTH=0.1 GRID_MIN=0 GRID_MAX=pi GRID_BIN=200 CLEAR=125000
theta2: HISTOGRAM ARG=puck2.theta BANDWIDTH=0.1 GRID_MIN=0 GRID_MAX=pi GRID_BIN=200 CLEAR=125000
theta3: HISTOGRAM ARG=puck3.theta BANDWIDTH=0.1 GRID_MIN=0 GRID_MAX=pi GRID_BIN=200 CLEAR=125000
theta4: HISTOGRAM ARG=puck4.theta BANDWIDTH=0.1 GRID_MIN=0 GRID_MAX=pi GRID_BIN=200 CLEAR=125000
theta5: HISTOGRAM ARG=puck5.theta BANDWIDTH=0.1 GRID_MIN=0 GRID_MAX=pi GRID_BIN=200 CLEAR=125000
theta6: HISTOGRAM ARG=puck6.theta BANDWIDTH=0.1 GRID_MIN=0 GRID_MAX=pi GRID_BIN=200 CLEAR=125000
theta7: HISTOGRAM ARG=puck7.theta BANDWIDTH=0.1 GRID_MIN=0 GRID_MAX=pi GRID_BIN=200 CLEAR=125000
theta8: HISTOGRAM ARG=puck8.theta BANDWIDTH=0.1 GRID_MIN=0 GRID_MAX=pi GRID_BIN=200 CLEAR=125000
theta9: HISTOGRAM ARG=puck9.theta BANDWIDTH=0.1 GRID_MIN=0 GRID_MAX=pi GRID_BIN=200 CLEAR=125000
theta10: HISTOGRAM ARG=puck10.theta BANDWIDTH=0.1 GRID_MIN=0 GRID_MAX=pi GRID_BIN=200 CLEAR=125000
theta11: HISTOGRAM ARG=puck11.theta BANDWIDTH=0.1 GRID_MIN=0 GRID_MAX=pi GRID_BIN=200 CLEAR=125000

DUMPGRID GRID=theta1 FILE=hhtheta1.dat STRIDE=125000
DUMPGRID GRID=theta2 FILE=hhtheta2.dat STRIDE=125000
DUMPGRID GRID=theta3 FILE=hhtheta3.dat STRIDE=125000
DUMPGRID GRID=theta4 FILE=hhtheta4.dat STRIDE=125000
DUMPGRID GRID=theta5 FILE=hhtheta5.dat STRIDE=125000
DUMPGRID GRID=theta6 FILE=hhtheta6.dat STRIDE=125000
DUMPGRID GRID=theta7 FILE=hhtheta7.dat STRIDE=125000
DUMPGRID GRID=theta8 FILE=hhtheta8.dat STRIDE=125000
DUMPGRID GRID=theta9 FILE=hhtheta9.dat STRIDE=125000
DUMPGRID GRID=theta10 FILE=hhtheta10.dat STRIDE=125000
DUMPGRID GRID=theta11 FILE=hhtheta11.dat STRIDE=125000

# Deriving 2D free energy profiles for pucker theta-phi

pucker1: HISTOGRAM ARG=puck1.theta,puckp1.phi BANDWIDTH=0.1,0.1 GRID_MIN=0,-pi GRID_MAX=pi,pi GRID_BIN=200,200 
pucker2: HISTOGRAM ARG=puck2.theta,puckp2.phi BANDWIDTH=0.1,0.1 GRID_MIN=0,-pi GRID_MAX=pi,pi GRID_BIN=200,200 
pucker3: HISTOGRAM ARG=puck3.theta,puckp3.phi BANDWIDTH=0.1,0.1 GRID_MIN=0,-pi GRID_MAX=pi,pi GRID_BIN=200,200 
pucker4: HISTOGRAM ARG=puck4.theta,puckp4.phi BANDWIDTH=0.1,0.1 GRID_MIN=0,-pi GRID_MAX=pi,pi GRID_BIN=200,200 
pucker5: HISTOGRAM ARG=puck5.theta,puckp5.phi BANDWIDTH=0.1,0.1 GRID_MIN=0,-pi GRID_MAX=pi,pi GRID_BIN=200,200 
pucker6: HISTOGRAM ARG=puck6.theta,puckp6.phi BANDWIDTH=0.1,0.1 GRID_MIN=0,-pi GRID_MAX=pi,pi GRID_BIN=200,200 
pucker7: HISTOGRAM ARG=puck7.theta,puckp7.phi BANDWIDTH=0.1,0.1 GRID_MIN=0,-pi GRID_MAX=pi,pi GRID_BIN=200,200 
pucker8: HISTOGRAM ARG=puck8.theta,puckp8.phi BANDWIDTH=0.1,0.1 GRID_MIN=0,-pi GRID_MAX=pi,pi GRID_BIN=200,200
pucker9: HISTOGRAM ARG=puck9.theta,puckp9.phi BANDWIDTH=0.1,0.1 GRID_MIN=0,-pi GRID_MAX=pi,pi GRID_BIN=200,200 
pucker10: HISTOGRAM ARG=puck10.theta,puckp10.phi BANDWIDTH=0.1,0.1 GRID_MIN=0,-pi GRID_MAX=pi,pi GRID_BIN=200,200 
pucker11: HISTOGRAM ARG=puck11.theta,puckp11.phi BANDWIDTH=0.1,0.1 GRID_MIN=0,-pi GRID_MAX=pi,pi GRID_BIN=200,200

ffpucker1: CONVERT_TO_FES GRID=pucker1 TEMP=310.15
ffpucker2: CONVERT_TO_FES GRID=pucker2 TEMP=310.15
ffpucker3: CONVERT_TO_FES GRID=pucker3 TEMP=310.15
ffpucker4: CONVERT_TO_FES GRID=pucker4 TEMP=310.15
ffpucker5: CONVERT_TO_FES GRID=pucker5 TEMP=310.15
ffpucker6: CONVERT_TO_FES GRID=pucker6 TEMP=310.15
ffpucker7: CONVERT_TO_FES GRID=pucker7 TEMP=310.15
ffpucker8: CONVERT_TO_FES GRID=pucker8 TEMP=310.15
ffpucker9: CONVERT_TO_FES GRID=pucker9 TEMP=310.15
ffpucker10: CONVERT_TO_FES GRID=pucker10 TEMP=310.15
ffpucker11: CONVERT_TO_FES GRID=pucker11 TEMP=310.15

DUMPGRID GRID=ffpucker1 FILE=ffpucker1.dat 
DUMPGRID GRID=ffpucker2 FILE=ffpucker2.dat 
DUMPGRID GRID=ffpucker3 FILE=ffpucker3.dat 
DUMPGRID GRID=ffpucker4 FILE=ffpucker4.dat 
DUMPGRID GRID=ffpucker5 FILE=ffpucker5.dat 
DUMPGRID GRID=ffpucker6 FILE=ffpucker6.dat 
DUMPGRID GRID=ffpucker7 FILE=ffpucker7.dat
DUMPGRID GRID=ffpucker8 FILE=ffpucker8.dat
DUMPGRID GRID=ffpucker9 FILE=ffpucker9.dat 
DUMPGRID GRID=ffpucker10 FILE=ffpucker10.dat
DUMPGRID GRID=ffpucker11 FILE=ffpucker11.dat


