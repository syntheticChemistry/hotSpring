#!/bin/bash
# gpu-ctl — GPU device control wrapper for toadStool
#
# Driver operations (swap, bind, unbind, setup) delegate to toadstool for
# safe lifecycle management with rollback, watchdog, and driver_override cleanup.
# Direct sysfs writes are only used for read-only status and power pinning.
#
# Usage:
#   gpu-ctl swap   BDF DRIVER        # Hot-swap to new driver (via toadstool)
#   gpu-ctl d0     BDF               # Force D0 + pin power=on
#   gpu-ctl status                    # Show all GPU states
#   gpu-ctl setup                     # Full dual Titan V setup (via toadstool)

set -euo pipefail

sysfs_write() {
    echo "$2" | sudo -n tee "$1" > /dev/null 2>&1
}

require_toadstool() {
    if ! command -v toadstool &>/dev/null; then
        echo "ERROR: toadstool not found. Install from plasmidBin:"
        echo "       cd infra/plasmidBin && ./fetch.sh --primal toadstool"
        echo "       sudo install -m 755 primals/x86_64-unknown-linux-musl/toadstool /usr/local/bin/"
        exit 1
    fi
}

cmd_swap() {
    require_toadstool
    local bdf="$1" target="$2"
    echo "Swapping $bdf → $target (via toadstool)"
    toadstool device swap "$bdf" "$target"
}

cmd_d0() {
    local bdf="$1"
    sysfs_write "/sys/bus/pci/devices/$bdf/power/control" "on"
    sysfs_write "/sys/bus/pci/devices/$bdf/d3cold_allowed" "0"
    local pwr=$(cat "/sys/bus/pci/devices/$bdf/power_state" 2>/dev/null || echo "?")
    echo "$bdf: power=$pwr (pinned D0)"
}

cmd_status() {
    echo "╔══ GPU Status ══════════════════════════════════════════╗"
    for dev in $(find /sys/bus/pci/devices/ -maxdepth 1 -name "0000:*" | sort); do
        local bdf=$(basename "$dev")
        local class=$(cat "$dev/class" 2>/dev/null || echo "?")
        case "$class" in
            0x030000|0x030200)
                local vendor=$(cat "$dev/vendor" 2>/dev/null)
                local device=$(cat "$dev/device" 2>/dev/null)
                local drv=$(basename "$(readlink "$dev/driver" 2>/dev/null)" 2>/dev/null || echo "unbound")
                local pwr=$(cat "$dev/power_state" 2>/dev/null || echo "?")
                local vname="?"
                case "$vendor" in
                    0x10de) vname="NVIDIA" ;;
                    0x1002) vname="AMD" ;;
                    0x8086) vname="Intel" ;;
                esac
                printf "║ %-14s %-8s %s:%s  driver=%-12s power=%s\n" "$bdf" "$vname" "$vendor" "$device" "$drv" "$pwr"
                ;;
        esac
    done
    echo "╚═════════════════════════════════════════════════════════╝"
}

cmd_setup() {
    require_toadstool
    echo ">>> Setting up dual Titan V (oracle + VFIO target)..."

    local ORACLE="0000:03:00.0"
    local TARGET="0000:4a:00.0"

    toadstool device swap "$TARGET" vfio
    cmd_d0 "$TARGET"

    local oracle_drv=$(basename "$(readlink "/sys/bus/pci/devices/$ORACLE/driver" 2>/dev/null)" 2>/dev/null || echo "none")
    echo "Oracle ($ORACLE): $oracle_drv"

    echo ""
    cmd_status
    echo ""
    echo "Ready. Run tests with:"
    echo "  TOADSTOOL_VFIO_BDF=$TARGET cargo test --test hw_nv_vfio --features vfio -- --ignored --test-threads=1"
}

case "${1:-help}" in
    swap)   cmd_swap "$2" "$3" ;;
    d0)     cmd_d0 "$2" ;;
    status) cmd_status ;;
    setup)  cmd_setup ;;
    *)
        echo "gpu-ctl — toadStool GPU device control"
        echo ""
        echo "Usage:"
        echo "  gpu-ctl status                 Show all GPUs"
        echo "  gpu-ctl setup                  Configure dual Titan V"
        echo "  gpu-ctl swap BDF DRIVER        Hot-swap to new driver"
        echo "  gpu-ctl d0 BDF                 Force D0 power state"
        echo ""
        echo "Driver operations delegate to toadstool (ember/cylinder) for safe"
        echo "swap lifecycle with rollback, watchdog, and driver_override cleanup."
        ;;
esac
