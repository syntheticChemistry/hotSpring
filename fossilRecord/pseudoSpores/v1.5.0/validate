#!/usr/bin/env bash
# pseudoSpore GuideStone self-validation — thin Rust launcher
# All logic lives in nest-validate (pure Rust). This script locates the binary.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Binary resolution order:
# 1. Bundled in ./bin/
# 2. In PATH
# 3. In known build location relative to hotSpring root
resolve_binary() {
    if [[ -x "$SCRIPT_DIR/bin/nest-validate" ]]; then
        echo "$SCRIPT_DIR/bin/nest-validate"
    elif command -v nest-validate &>/dev/null; then
        command -v nest-validate
    elif [[ -x "$SCRIPT_DIR/../control/plumed_nest/nest-validate/target/release/nest-validate" ]]; then
        echo "$SCRIPT_DIR/../control/plumed_nest/nest-validate/target/release/nest-validate"
    else
        return 1
    fi
}

BINARY="$(resolve_binary)" || {
    echo "ERROR: nest-validate binary not found."
    echo ""
    echo "Build it with:"
    echo "  cd control/plumed_nest/nest-validate && cargo build --release"
    echo ""
    echo "Or place a musl-static binary in: $SCRIPT_DIR/bin/nest-validate"
    exit 1
}

exec "$BINARY" guidestone validate "$SCRIPT_DIR"
